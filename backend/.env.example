# Smart Academic Companion - Environment Variables Example
# Copy this to .env and fill in your keys

# OpenAI API key (optional - only used if OpenRouter key is not set)
# OPENAI_API_KEY=sk-your-openai-key

# OpenRouter API key (takes precedence over OpenAI key)
# OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# OpenRouter model override (default: meta-llama/llama-3-8b-instruct:free)
# OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free


